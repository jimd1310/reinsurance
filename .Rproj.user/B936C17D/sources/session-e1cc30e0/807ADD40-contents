## Finding the Target Excess of Loss Deductible

We know from previous results that $d = 3.408721$ leads to a ruin probability of $0.00198$, which is much too low and will give a confidence interval above $(0.9895, 0.9905)$. Therefore, it seems reasonable that $d_{99\%}$ lies in the range $(3.408721, 5.5)$, so we will search this range.

```{r chunk16}

set.seed(3162)
nsim <- 5e4

# A rough search for d based on an educated guess
d_grid_rough <- seq(3.4, 5.5, 0.1)
d_search_rough <- sapply(d_grid_rough, function(d) prob_ruin(nsim, 
                                       t = 60, lambda = 2, 
                                       sev_distribution = "gamma", 
                                       shape = 0.3162, rate = 0.229245, 
                                       policy = 'EoL', 
                                       d = d))
# Find a new range of values to search by filtering
d_prob_rough <- 1 - d_search_rough
d_CI_rough <- data.frame(lower = d_prob_rough - 1.96 * se(d_prob_rough, nsim), 
                         upper = d_prob_rough + 1.96 * se(d_prob_rough, nsim))
filter_index_rough <- which(abs(d_CI_rough$lower - 0.9895) < 1e-3 &
                            abs(d_CI_rough$upper - 0.9905) < 1e-3)
d_range_rough <- d_grid_rough[filter_index_rough]


# Final search for d
nsim <- 2e5

d_grid_fine <- seq(min(d_range_rough), max(d_range_rough), 0.001)
d_search_fine <- sapply(d_grid_fine, function(d) prob_ruin(nsim, 
                                             t = 60, lambda = 2, 
                                             sev_distribution = "gamma", 
                                             shape = 0.3162, rate = 0.229245, 
                                             policy = 'EoL', 
                                             d = d))
# Get the survival probabilities
d_prob_fine <- 1 - d_search_fine

# Compute confidence intervals
d_CI_fine <- data.frame(lower = d_prob_fine - 1.96 * se(d_prob_fine, nsim), 
                        upper = d_prob_fine + 1.96 * se(d_prob_fine, nsim))
# Filter
d_filter_index_fine <- which.min(abs(d_CI_fine$lower - 0.9895) +
                                 abs(d_CI_fine$upper - 0.9905))
d99 <- d_grid_fine[d_filter_index_fine]

# Display Results
profit_d99 <- profit_reinsurance(t = 60, lambda = 2, sev_distribution = 'gamma', 
                                 shape = 0.3162, rate = 0.229245, policy = 'EoL', 
                                 d = d99)
print(cbind(d_CI_fine[d_filter_index_fine, ], d99, profit_d99))

```

# Sensitivity Analysis of Model Parameters 

Now, we move on to scenario II with reinsurance product B to conduct a sensitivity analysis. We will produce the following results for the parameters $c_0$, $\theta$, and $\xi$:

1. Shocking parameters to find the change of ruin probability for a percentage change in the parameters.

2. Plots of the Lundberg upper bound for each parameter, with actual ruin probabilities also calculated to test the robustness of the bound.

3. Heatmaps to capture the joint effect of $\theta$ and $\xi$ on the ruin probability and company profitability. 

## Parameter Shock

We perturb each parameter by $\pm \mu x$ and recompute $\psi_{60}$, for some fraction $\mu \in (0, 1)$.

```{r chunk17}

set.seed(3162)
nsim <- 1e6
c0 <- 50
theta <- 0.07
xi <- 0.1

parameter_shock <- function(parameter, psi, mu, c0, theta, xi) {
  if (parameter == 'c0') {
    delta <- mu * c0
    forward <- prob_ruin(nsim, t = 60, lambda = 2, sev_distribution = 'gamma', 
                         shape = 0.3162, rate = 0.229245, policy = 'EoL', 
                         d = 3.408721, c0 = c0 + delta, theta = theta, xi = xi)
    backward <- prob_ruin(nsim, t = 60, lambda = 2, sev_distribution = 'gamma', 
                          shape = 0.3162, rate = 0.229245, policy = 'EoL', 
                          d = 3.408721, c0 = c0 - delta, theta = theta, xi = xi)
  } else if (parameter == 'theta') {
    delta <- mu * theta
    forward <- prob_ruin(nsim, t = 60, lambda = 2, sev_distribution = 'gamma', 
                         shape = 0.3162, rate = 0.229245, policy = 'EoL', 
                         d = 3.408721, c0 = c0, theta = theta + delta, xi = xi)
    backward <- prob_ruin(nsim, t = 60, lambda = 2, sev_distribution = 'gamma', 
                          shape = 0.3162, rate = 0.229245, policy = 'EoL', 
                          d = 3.408721, c0 = c0, theta = theta - delta, xi = xi)
  } else if (parameter == 'xi') {
    delta <- mu * xi
    forward <- prob_ruin(nsim, t = 60, lambda = 2, sev_distribution = 'gamma', 
                         shape = 0.3162, rate = 0.229245, policy = 'EoL', 
                         d = 3.408721, c0 = c0, theta = theta, xi = xi + delta)
    backward <- prob_ruin(nsim, t = 60, lambda = 2, sev_distribution = 'gamma', 
                          shape = 0.3162, rate = 0.229245, policy = 'EoL', 
                          d = 3.408721, c0 = c0, theta = theta, xi = xi - delta)
  }
  c(forward - psi, backward - psi)
}

shock_c0_0.1 <- parameter_shock('c0', psi60_II_B, 0.1, c0, theta, xi)
shock_theta_0.1 <- parameter_shock('theta', psi60_II_B, 0.1, c0, theta, xi)
shock_xi_0.1 <- parameter_shock('xi', psi60_II_B, 0.1, c0, theta, xi)

shock_c0_0.2 <- parameter_shock('c0', psi60_II_B, 0.2, c0, theta, xi)
shock_theta_0.2 <- parameter_shock('theta', psi60_II_B, 0.2, c0, theta, xi)
shock_xi_0.2 <- parameter_shock('xi', psi60_II_B, 0.2, c0, theta, xi)

shock_summary <- data.frame(shock0.1 = cbind(shock_c0_0.1, 
